<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>MangaLib</RootNamespace>
  </PropertyGroup>

	<PropertyGroup>
		<PackageId>UnofficialMangaLibAPI</PackageId>
		<Version>1.0.2</Version>
		<Authors>equmag</Authors>
		<Description>Unofficially maintained library for MangaLib, RanobeLib, AuthorToday and Renovels on .NET</Description>

		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<PackageOutputPath>$(MSBuildThisFileDirectory)nuget</PackageOutputPath>
	</PropertyGroup>
</Project>
